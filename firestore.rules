rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to check if the user is access-authorized for a given email document
    function isOwner(email) {
      return isSignedIn() 
          && request.auth.token.email.lower() == email.lower();
    }

    // Helper to validate email formatting
    function isValidEmail(email) {
      return email is string 
          && email.size() > 3 
          && email.size() <= 120;
    }

    // Helper to validate UserLedgerData schema
    function isValidUserLedgerData(data) {
      return data.keys().hasAll(['transactions', 'expenses', 'shopName', 'updatedAt'])
          && data.keys().hasOnly(['transactions', 'expenses', 'shopName', 'updatedAt', 'outOfStockItems', 'productRates'])
          && data.transactions is list
          && data.expenses is list
          && data.shopName is string
          && data.shopName.size() <= 150
          && (data.updatedAt is int || data.updatedAt is number)
          && (!('outOfStockItems' in data) || data.outOfStockItems is list)
          && (!('productRates' in data) || data.productRates is list);
    }

    // Helper to validate VerifiedMemo schema
    function isValidVerifiedMemo(data) {
      return data.keys().hasAll(['invoiceNo', 'shopName', 'customerName', 'date', 'netTotal', 'verifiedText', 'createdBy'])
          && data.invoiceNo is string
          && data.invoiceNo.size() <= 100
          && data.shopName is string
          && data.shopName.size() <= 150
          && data.customerName is string
          && data.customerName.size() <= 150
          && data.date is string
          && data.netTotal is number
          && data.verifiedText is string
          && data.verifiedText.size() <= 1000
          && data.createdBy is string;
    }

    match /users/{email} {
      allow get: if isOwner(email) && isValidEmail(email);
      allow create, update: if isOwner(email) 
                             && isValidEmail(email) 
                             && isValidUserLedgerData(request.resource.data);
      allow delete: if false;
    }

    match /verified_memos/{invoiceNo} {
      allow get: if true; // anyone can retrieve a memo for validation
      allow create, update: if isSignedIn()
                             && request.auth.token.email.lower() == request.resource.data.createdBy.lower()
                             && isValidVerifiedMemo(request.resource.data);
      allow delete: if false;
    }
  }
}
