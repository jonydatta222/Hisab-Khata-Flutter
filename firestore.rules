rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to validate document ID / email format
    function isValidEmail(email) {
      return email is string 
          && email.size() > 3 
          && email.size() <= 120;
    }

    // Helper to validate UserLedgerData schema (Encrypted)
    function isValidUserLedgerData(data) {
      return data.keys().hasAll(['encryptedData', 'passcodeHash', 'updatedAt'])
          && data.keys().size() == 3
          && data.encryptedData is string
          && data.encryptedData.size() <= 1048576
          && data.passcodeHash is string
          && data.passcodeHash.size() == 64
          && data.updatedAt is int;
    }

    match /users/{email} {
      allow get: if isValidEmail(email);
      allow create: if isValidEmail(email) 
                    && isValidUserLedgerData(request.resource.data);
      allow update: if isValidEmail(email) 
                    && isValidUserLedgerData(request.resource.data)
                    && (resource.data.get('passcodeHash', null) == null || request.resource.data.passcodeHash == resource.data.passcodeHash);
      allow delete: if false;
    }
  }
}
