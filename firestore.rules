rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to validate document ID / email format
    function isValidEmail(email) {
      return email is string 
          && email.size() > 3 
          && email.size() <= 120;
    }

    // Helper to validate UserLedgerData schema
    function isValidUserLedgerData(data) {
      return data.keys().hasAll(['transactions', 'expenses', 'shopName', 'updatedAt'])
          && data.keys().size() == 4
          && data.transactions is list
          && data.expenses is list
          && data.shopName is string
          && data.shopName.size() <= 150
          && data.updatedAt is int;
    }

    match /users/{email} {
      allow get: if isValidEmail(email);
      allow create, update: if isValidEmail(email) 
                             && isValidUserLedgerData(request.resource.data);
      allow delete: if false;
    }
  }
}
