{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "Represents a sales or payment transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "product": { "type": "string" },
        "amount": { "type": "number" },
        "isCash": { "type": "boolean" },
        "customer": { "type": "string" }
      },
      "required": ["id", "date", "time", "product", "amount", "isCash"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Represents a business expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" }
      },
      "required": ["id", "date", "time", "description", "amount"]
    },
    "OutOfStockItem": {
      "title": "Out Of Stock Item",
      "description": "Represents an item that is out of stock",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "dateAdded": { "type": "string" }
      },
      "required": ["id", "name", "dateAdded"]
    },
    "ProductRateItem": {
      "title": "Product Rate Item",
      "description": "Represents the buying price of an item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "buyingPrice": { "type": "number" },
        "dateAdded": { "type": "string" }
      },
      "required": ["id", "name", "buyingPrice", "dateAdded"]
    },
    "UserLedgerData": {
      "title": "User Ledger Data",
      "description": "Ledger data containing all transactions, expenses, out of stock items, and product rates synced for a specific email",
      "type": "object",
      "properties": {
        "transactions": { "type": "array" },
        "expenses": { "type": "array" },
        "shopName": { "type": "string" },
        "updatedAt": { "type": "number" },
        "outOfStockItems": { "type": "array" },
        "productRates": { "type": "array" }
      },
      "required": ["transactions", "expenses", "shopName", "updatedAt"]
    },
    "VerifiedMemo": {
      "title": "Verified Memo",
      "description": "Memo details stored for public validation and anti-AI-forgery protection",
      "type": "object",
      "properties": {
        "invoiceNo": { "type": "string" },
        "shopName": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "date": { "type": "string" },
        "subTotal": { "type": "number" },
        "discount": { "type": "number" },
        "netTotal": { "type": "number" },
        "paid": { "type": "number" },
        "due": { "type": "number" },
        "items": { "type": "array" },
        "verifiedText": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["invoiceNo", "shopName", "customerName", "date", "netTotal", "verifiedText", "createdBy"]
    }
  },
  "firestore": {
    "users/{email}": {
      "schema": "UserLedgerData",
      "description": "User ledger document identified by clean lower-case email"
    },
    "verified_memos/{invoiceNo}": {
      "schema": "VerifiedMemo",
      "description": "Publicly readable memo validation document"
    }
  }
}
