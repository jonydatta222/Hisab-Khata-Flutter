{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "Represents a sales or payment transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "product": { "type": "string" },
        "amount": { "type": "number" },
        "isCash": { "type": "boolean" },
        "customer": { "type": "string" }
      },
      "required": ["id", "date", "time", "product", "amount", "isCash"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Represents a business expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" }
      },
      "required": ["id", "date", "time", "description", "amount"]
    },
    "UserLedgerData": {
      "title": "User Ledger Data",
      "description": "Ledger data encrypted with a 6-digit PIN containing transactions, expenses, and shopName",
      "type": "object",
      "properties": {
        "encryptedData": { "type": "string" },
        "passcodeHash": { "type": "string" },
        "updatedAt": { "type": "number" }
      },
      "required": ["encryptedData", "passcodeHash", "updatedAt"]
    }
  },
  "firestore": {
    "users/{email}": {
      "schema": "UserLedgerData",
      "description": "User ledger document identified by clean lower-case email"
    }
  }
}
