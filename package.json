{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "generate-assets": "node generate-assets.js && (npx capacitor-assets generate --android || true)",
    "prebuild": "npm run generate-assets",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
